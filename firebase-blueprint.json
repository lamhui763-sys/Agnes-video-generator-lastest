{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A user's project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ExperienceEntry": {
      "title": "Experience Entry",
      "description": "Records of failed attempts, AI improvements, and system errors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["image_review", "video_review", "system_error", "api_error", "workflow_error"] },
        "sceneId": { "type": "string" },
        "projectId": { "type": "string" },
        "originalPrompt": { "type": "string" },
        "optimizedPrompt": { "type": "string" },
        "critique": { "type": "string" },
        "score": { "type": "number" },
        "passed": { "type": "boolean" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "errorName": { "type": "string" },
        "errorMessage": { "type": "string" },
        "errorStack": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "type", "userId", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "User projects"
    },
    "/experience_library/{entryId}": {
      "schema": "ExperienceEntry",
      "description": "Accumulated AI experience and failure logs"
    }
  }
}
